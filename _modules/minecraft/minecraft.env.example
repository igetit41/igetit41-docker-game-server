# Copy to minecraft.env in this directory (minecraft.env is gitignored — never commit).
# Terraform reads this file at apply time and delivers it to the VM automatically.
# Get a CurseForge API key: https://console.curseforge.com/
#
# CurseForge keys contain $ — wrap in single quotes for local editing.
# Terraform delivers GAME_ENV_B64 + GAME_API_KEY_B64 metadata (see game-server.sh).

CF_API_KEY='your-curseforge-api-key'

CF_PAGE_URL=https://www.curseforge.com/minecraft/modpacks/all-the-mods-9
# CF_SLUG=all-the-mods-9
# CF_FILE_ID=1234567

MEMORY=12G

# Modpack world preset for dedicated servers (maps to server.properties level-type).
# Fractured Opolis: fractured:fractured. Other BBL skyblock packs often use skyblockbuilder:skyblock.
# Only affects new world generation — wipe data/world when changing modpacks or this value.
# LEVEL_TYPE=fractured:fractured

SERVER_NAME=game-server
MODE=survival
DIFFICULTY=hard
PVP=FALSE
ALLOW_FLIGHT=TRUE
