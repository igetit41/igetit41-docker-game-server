# Copy to minecraft.env in this directory (minecraft.env is gitignored).
# All tunable server settings go here — compose.yaml only wires the image and port.
# Get a CurseForge API key: https://console.curseforge.com/

CF_API_KEY=your-curseforge-api-key

# Modpack (pick one approach):
CF_PAGE_URL=https://www.curseforge.com/minecraft/modpacks/all-the-mods-9
# CF_SLUG=all-the-mods-9
# CF_FILE_ID=1234567

# Server resources and rules
MEMORY=12G
SERVER_NAME=game-server
MODE=survival
DIFFICULTY=hard
PVP=FALSE
ALLOW_FLIGHT=TRUE
